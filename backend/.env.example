# ==========================================================
# Enterprise IDP Backend Configuration
# ==========================================================

# ==========================================================
# Database
# ==========================================================

DATABASE_URL=sqlite+aiosqlite:///./idp.db

# ==========================================================
# JWT Authentication
# ==========================================================

JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ==========================================================
# AWS
# ==========================================================

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ==========================================================
# GitHub
# ==========================================================

GITHUB_TOKEN=
GITHUB_ORG=

# ==========================================================
# Terraform
# ==========================================================

TERRAFORM_BINARY=terraform

TERRAFORM_ROOT_DIR=../terraform
TERRAFORM_BOOTSTRAP_DIR=../terraform/bootstrap
TERRAFORM_ENVIRONMENTS_DIR=../terraform/environments
TERRAFORM_MODULES_DIR=../terraform/modules

TERRAFORM_STATE_BUCKET=enterprise-idp-tfstate-684707795435
TERRAFORM_STATE_KEY_PREFIX=idp
TERRAFORM_LOCK_TABLE=enterprise-idp-lock

# ==========================================================
# Docker
# ==========================================================

DOCKER_REGISTRY=

# ==========================================================
# OpenAI
# ==========================================================

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# ==========================================================
# EC2 Defaults
# ==========================================================

EC2_AMI_ID=ami-01a00762f46d584a1
EC2_DEFAULT_INSTANCE_TYPE=t3.micro

EC2_DEFAULT_SUBNET_ID=subnet-07c63b8cddc483f21
EC2_DEFAULT_SECURITY_GROUP_ID=sg-0e58d1c97123364b9

EC2_DEFAULT_IAM_PROFILE=enterprise-idp-dev-instance-profile

EC2_DEFAULT_KEY_NAME=idp

EC2_USER_DATA_FILE=../scripts/user-data.sh